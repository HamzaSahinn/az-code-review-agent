{
  "AzureDevOps": {
    "ServerUrl": "https://devops.contoso.com",
    "Collection": "DefaultCollection",
    "Pat": "-- set via environment variable or user secrets --",
    "ApiVersion": "7.0",
    "AgentUserId": "00000000-0000-0000-0000-000000000000",
    "AgentDisplayName": "CodeReviewAgent"
  },
  "Ai": {
    "Provider": "AzureOpenAI",
    "AzureOpenAi": {
      "Endpoint": "https://your-resource.openai.azure.com/",
      "DeploymentName": "gpt-4o",
      "ApiKey": "-- set via environment variable or user secrets --"
    },
    "Ollama": {
      "Endpoint": "http://localhost:11434",
      "ModelId": "llama3.1"
    },
    "MaxTokensPerFile": 8000,
    "MaxTokensPerReview": 100000,
    "Temperature": 0.2
  },
  "WebhookAuth": {
    "Username": "webhook",
    "Password": "-- set via environment variable or user secrets --"
  },
  "Review": {
    "TriggerCommands": ["/review", "/ask"],
    "FileExtensions": [".cs", ".ts", ".js", ".py", ".java", ".go", ".sql"],
    "ExcludePatterns": ["*.Designer.cs", "*.generated.cs", "*/Migrations/*"],
    "MaxFilesPerReview": 50,
    "MaxFileSizeBytes": 102400
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}
